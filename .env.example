# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=                    # Required for Ollama web search (https://ollama.com/settings/keys)
OLLAMA_IMAGE_MODEL=gemma4:31b-cloud    # Vision model used by analyze_image
OLLAMA_WEB_SEARCH_URL=https://ollama.com/api/web_search

# Eve model override (defaults to local Ollama)
EVE_MODEL=ollama/glm-5.2:cloud

# Persistence configuration
GOLDFISH_HOME=${HOME}/.goldfish

# MCP server (optional) — used by agent/connections/mcp.ts
# EVE_MCP_URL=http://127.0.0.1:3000/sse

# Self-improvement schedule
GOLDFISH_ENABLE_SELF_IMPROVEMENT=true

# Subagent model override
GOLDFISH_SUBAGENT_MODEL=ollama/glm-5.2:cloud
